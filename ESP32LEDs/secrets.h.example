// Template for ESP32 secrets. Copy to secrets.h and fill in your values:
//   cp secrets.h.example secrets.h
// secrets.h is gitignored so your credentials are never committed.
#pragma once

#define WIFI_SSID     "YourWiFiNetwork"
#define WIFI_PASSWORD "YourWiFiPassword"

// Shared API key — must match ESP32_API_KEY in the Python-side .env.
// Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#define CLANK_API_KEY ""

// ---- MQTT (RGB firmware) ----
// Broker address = the PC running mosquitto + Clank. On the host hotspot the
// PC is the gateway at 10.42.0.1; on a home LAN use the PC's LAN IP.
#define MQTT_BROKER   "10.42.0.1"
#define MQTT_PORT     1883
// Broker credentials — must match the mosquitto passwd entry and Clank's .env.
#define MQTT_USER     "clank"
#define MQTT_PASS     ""

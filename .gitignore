# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Environment — never commit secrets
.env
.env.*

# Registered device API keys — stored in plaintext, never commit
config/devices.json

# Local hardware inventory — not part of the project
component_inventory.json

# TLS certificates and keys — never commit private keys
certs/

# Generated ESP32 firmware cert header — contains the device's private key
ESP32LEDs/cert.h

# ESP32 WiFi credentials + API key (committed template: secrets.h.example)
ESP32LEDs/secrets.h

# Model weights — large binaries, fetched by scripts/fetch_moonshine.sh.
# Ignore the contents (so git can still descend) rather than the directory
# itself, so the one small model we ship can be re-included below.
models/*
# ...except our own small, hash-pinned "hey clank" wake model, which ships in
# the repo (re-include the directory first, then the file).
!models/wakeword/
models/wakeword/*
!models/wakeword/hey_clank.onnx

# Logs
logs/

# Generated during install/netron
install.log
*.svg

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
